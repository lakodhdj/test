# --- DATABASE (PostgreSQL) ---
# Локальный запуск использует localhost и SQLite, если PostgreSQL не доступен
DB_USER=tim
DB_PASSWORD=qwerty1
DB_NAME=ecommerce_db
DB_HOST=localhost
DB_PORT=5432
DB_USE_SQLITE=true

# --- REDIS (Для сессий и токенов) ---
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MINIO (S3 Storage) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=admin_minio
MINIO_ROOT_PASSWORD=password_minio
MINIO_BUCKET_NAME=product-images
# Публичный URL для доступа к картинкам с фронтенда (через прокси или напрямую)
MINIO_PUBLIC_URL=http://localhost:9000

# --- JWT AUTH ---
JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- TOKENS ---
EMAIL_VERIFICATION_TOKEN_TIME_HOUR=1
EMAIL_PASSWORD_RESET_TOKEN_TIME_HOUR=2

# --- URLS ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000